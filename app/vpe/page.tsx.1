'use client';

// 1. Core React & Next.js
import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import Link from 'next/link';

// 2. Firebase & Auth
import { auth, db } from '@/lib/firebase';
import { 
  collection, 
  query, 
  orderBy, 
  onSnapshot, 
  doc, 
  updateDoc, 
  deleteDoc,
  Timestamp 
} from 'firebase/firestore';
import { useAuth } from '@/context/AuthContext';

// 3. Icons & UI
import { 
  Trash2, 
  Plus, 
  Settings, 
  Calendar, 
  ShieldAlert, 
  LogOut, 
  ChevronLeft,
  Loader2,
  User
} from 'lucide-react';

interface Slot {
  role: string;
  userId?: string;
  userName?: string;
}

interface Meeting {
  id: string;
  timestamp: Timestamp;
  slots: Slot[];
}

export default function VPEPage() {
  const { user, loading: authLoading } = useAuth();
  const router = useRouter();
  
  // State
  const [meetings, setMeetings] = useState<Meeting[]>([]);
  const [newRoleNames, setNewRoleNames] = useState<{ [key: string]: string }>({});
  const [actionLoading, setActionLoading] = useState<string | null>(null);

  const isVPE = user?.email === process.env.NEXT_PUBLIC_VPE_EMAIL;

  // Fetch Meetings
  useEffect(() => {
    if (!isVPE) return;

    const q = query(collection(db, "meetings"), orderBy("timestamp", "desc"));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const meetingData = snapshot.docs.map(doc => ({
        id: doc.id, // Explicitly mapping the Firestore ID
        ...doc.data()
      })) as Meeting[];
      setMeetings(meetingData);
    });

    return () => unsubscribe();
  }, [isVPE]);

  // Security Redirect
  useEffect(() => {
    if (!authLoading && !isVPE) {
      // Optional: auto-redirect non-VPEs
      // router.push('/'); 
    }
  }, [authLoading, isVPE, router]);

  if (authLoading) return <div className="p-10 text-center"><Loader2 className="animate-spin mx-auto" /></div>;

  if (!isVPE) {
    return (
      <div className="max-w-2xl mx-auto mt-20 p-8 bg-red-50 text-red-600 rounded-2xl flex flex-col items-center gap-4 text-center border border-red-100">
        <ShieldAlert size={48} />
        <h1 className="text-2xl font-bold">Access Denied</h1>
        <p>You must be the Vice President of Education to view this page.</p>
        <Link href="/" className="text-sm underline font-medium">Return to Home</Link>
      </div>
    );
  }

  // --- ACTIONS ---

  const sanitizeSlots = (slots: Slot[]) => JSON.parse(JSON.stringify(slots));

  const handleAddRole = async (meetingId: string, currentSlots: Slot[]) => {
    const roleName = newRoleNames[meetingId]?.trim();
    if (!roleName) return;

    setActionLoading(`add-${meetingId}`);
    try {
      const meetingRef = doc(db, "meetings", meetingId);
      const updatedSlots = [...currentSlots, { role: roleName }];
      await updateDoc(meetingRef, { slots: sanitizeSlots(updatedSlots) });
      setNewRoleNames(prev => ({ ...prev, [meetingId]: "" }));
    } catch (err) {
      alert("Error adding role");
    } finally {
      setActionLoading(null);
    }
  };

  const handleRemoveRole = async (meetingId: string, currentSlots: Slot[], roleName: string) => {
    if (!confirm(`Remove "${roleName}"?`)) return;

    setActionLoading(`remove-${meetingId}-${roleName}`);
    try {
      const meetingRef = doc(db, "meetings", meetingId);
      const updatedSlots = currentSlots.filter(s => s.role !== roleName);
      await updateDoc(meetingRef, { slots: sanitizeSlots(updatedSlots) });
    } catch (err) {
      alert("Error removing role");
    } finally {
      setActionLoading(null);
    }
  };

  const handleDeleteMeeting = async (meetingId: string) => {
    if (!confirm("Delete this entire meeting? This is permanent.")) return;
    try {
      await deleteDoc(doc(db, "meetings", meetingId));
    } catch (err) {
      alert("Error deleting meeting");
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 pb-20">
      {/* HEADER */}
      <div className="bg-white border-b border-slate-200 sticky top-0 z-10">
        <div className="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-4">
            <Link href="/" className="p-2 hover:bg-slate-100 rounded-full transition-colors">
              <ChevronLeft size={20} />
            </Link>
            <div>
              <h1 className="text-xl font-black text-slate-800 flex items-center gap-2">
                <Settings size={20} className="text-purple-600" /> VPE Admin
              </h1>
            </div>
          </div>
          <button onClick={() => auth.signOut()} className="flex items-center gap-2 text-sm text-slate-500 hover:text-red-600 font-medium">
            <LogOut size={16} /> Sign Out
          </button>
        </div>
      </div>

      <main className="max-w-4xl mx-auto px-6 mt-8">
        <div className="space-y-8">
          {meetings.map((meeting) => (
            <div key={meeting.id} className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
              
              {/* Meeting Meta */}
              <div className="bg-slate-800 p-4 flex justify-between items-center text-white">
                <div className="flex items-center gap-3">
                  <Calendar size={18} className="text-purple-400" />
                  <span className="font-bold">
                    {meeting.timestamp.toDate().toLocaleDateString('en-GB', { 
                      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' 
                    })}
                  </span>
                </div>
                <button 
                  onClick={() => handleDeleteMeeting(meeting.id)}
                  className="text-xs font-bold bg-red-500/10 hover:bg-red-500 text-red-400 hover:text-white px-3 py-1.5 rounded-lg transition-all"
                >
                  Delete Meeting
                </button>
              </div>

              {/* Roles List */}
              <div className="p-6 grid grid-cols-1 md:grid-cols-2 gap-3">
                {meeting.slots.map((slot) => (
                  <div key={slot.role} className="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 group">
                    <div className="flex flex-col">
                      <span className="text-sm font-bold text-slate-700">{slot.role}</span>
                      {slot.userId && (
                        <span className="text-[10px] text-purple-600 font-medium flex items-center gap-1 uppercase tracking-wider">
                          <User size={10} /> {slot.userName}
                        </span>
                      )}
                    </div>
                    <button 
                      onClick={() => handleRemoveRole(meeting.id, meeting.slots, slot.role)}
                      disabled={!!actionLoading}
                      className="text-slate-300 hover:text-red-500 transition-colors p-1"
                    >
                      {actionLoading === `remove-${meeting.id}-${slot.role}` ? <Loader2 size={14} className="animate-spin" /> : <Trash2 size={16} />}
                    </button>
                  </div>
                ))}
              </div>

              {/* Add Role Section */}
              <div className="px-6 py-4 bg-slate-50/50 border-t border-slate-100 flex gap-2">
                <input 
                  type="text" 
                  placeholder="New role name..."
                  className="flex-1 bg-white border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all"
                  value={newRoleNames[meeting.id] || ""}
                  onChange={(e) => setNewRoleNames(prev => ({ ...prev, [meeting.id]: e.target.value }))}
                  onKeyDown={(e) => e.key === 'Enter' && handleAddRole(meeting.id, meeting.slots)}
                />
                <button 
                  onClick={() => handleAddRole(meeting.id, meeting.slots)}
                  disabled={!!actionLoading || !newRoleNames[meeting.id]?.trim()}
                  className="bg-slate-900 text-white hover:bg-purple-600 disabled:opacity-50 disabled:bg-slate-300 px-5 py-2 rounded-xl text-sm font-bold flex items-center gap-2 transition-all shadow-sm"
                >
                  {actionLoading === `add-${meeting.id}` ? <Loader2 size={16} className="animate-spin" /> : <Plus size={16} />}
                  Add Role
                </button>
              </div>

            </div>
          ))}

          {meetings.length === 0 && (
            <div className="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-slate-200">
              <p className="text-slate-400 font-medium">No meetings scheduled.</p>
            </div>
          )}
        </div>
      </main>
    </div>
  );
}
